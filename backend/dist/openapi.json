  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "access_token",
        "description": "Authenticated workspace cookie. Protected endpoints only return or mutate the current user's own records."
      }
    },
    "parameters": {
      "CsrfHeader": {
        "in": "header",
        "name": "X-CSRF-Token",
        "required": false,
        "schema": {
          "type": "string"
        },
        "description": "Required for mutating requests unless using the dev auth bypass."
      },
      "Page": {
        "in": "query",
        "name": "page",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1
        }
      },
      "PageSize": {
        "in": "query",
        "name": "pageSize",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1
        }
      },
      "JobsPage": {
        "in": "query",
        "name": "jobsPage",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1
        }
      },
      "JobsPageSize": {
        "in": "query",
        "name": "jobsPageSize",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1
        }
      },
      "ApplicantsPage": {
        "in": "query",
        "name": "applicantsPage",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1
        }
      },
      "ApplicantsPageSize": {
        "in": "query",
        "name": "applicantsPageSize",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "responses": {
      "InputError": {
        "description": "Validation error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorEnvelope"
            }
          }
        }
      },
      "DataError": {
        "description": "Data or not-found error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorEnvelope"
            }
          }
        }
      },
      "AuthError": {
        "description": "Authentication error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorEnvelope"
            }
          }
        }
      },
      "UserError": {
        "description": "User session error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorEnvelope"
            }
          }
        }
      }
    },
    "schemas": {
      "ErrorEnvelope": {
        "type": "object",
        "additionalProperties": {
          "type": ["string", "number", "boolean", "object", "array", "null"]
        }
      },
      "SignupRequest": {
        "type": "object",
        "properties": {
          "user_name": {
            "type": "string"
          },
          "user_email": {
            "type": "string",
            "format": "email"
          },
          "company_name": {
            "type": "string"
          },
          "user_pass": {
            "type": "string",
            "description": "Must include uppercase, lowercase, number, and symbol."
          }
        },
        "required": ["user_name", "user_email", "user_pass"]
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "user_email": {
            "type": "string",
            "format": "email"
          },
          "user_pass": {
            "type": "string"
          }
        },
        "required": ["user_email", "user_pass"]
      },
      "ForgotRequest": {
        "type": "object",
        "properties": {
          "user_email": {
            "type": "string",
            "format": "email"
          }
        },
        "required": ["user_email"]
      },
      "ResetPasswordRequest": {
        "type": "object",
        "properties": {
          "user_pass": {
            "type": "string"
          },
          "user_pass_conf": {
            "type": "string"
          }
        },
        "required": ["user_pass", "user_pass_conf"]
      },
      "OnboardingRequest": {
        "type": "object",
        "properties": {
          "company_name": {
            "type": "string"
          },
          "hiring_focus": {
            "type": "string"
          },
          "team_setup": {
            "type": "string"
          },
          "workflow_goal": {
            "type": "string"
          }
        },
        "required": [
          "company_name",
          "hiring_focus",
          "team_setup",
          "workflow_goal"
        ]
      },
      "CreateJobRequest": {
        "type": "object",
        "properties": {
          "job_title": {
            "type": "string"
          },
          "job_department": {
            "type": "string"
          },
          "job_location": {
            "type": "string"
          },
          "job_employment_type": {
            "type": "string"
          },
          "job_description": {
            "type": "string"
          },
          "job_experience_required": {
            "type": "string"
          },
          "job_responsibilities": {
            "type": "string"
          },
          "job_qualifications": {
            "type": "string"
          },
          "job_ai_criteria": {
            "type": ["array", "object", "string", "null"]
          },
          "job_shortlist_size": {
            "type": "integer"
          },
          "job_state": {
            "type": "string"
          },
          "job_salary_min": {
            "type": "number"
          },
          "job_salary_max": {
            "type": "number"
          },
          "workers_required": {
            "type": "integer"
          },
          "minimum_marks": {
            "type": "number"
          }
        },
        "required": [
          "job_title",
          "job_department",
          "job_location",
          "job_employment_type",
          "job_description"
        ]
      },
      "ApplicantInput": {
        "type": "object",
        "additionalProperties": true
      },
      "RunScreeningRequest": {
        "type": "object",
        "properties": {
          "jobId": {
            "type": "string"
          },
          "job_id": {
            "type": "string"
          },
          "jobTitle": {
            "type": "string"
          },
          "job_title": {
            "type": "string"
          }
        }
      },
      "ReviewDecisionItem": {
        "type": "object",
        "properties": {
          "applicant_id": {
            "type": "string"
          },
          "applicant_name": {
            "type": "string"
          },
          "job_title": {
            "type": "string"
          },
          "shortlisted": {
            "type": "boolean"
          }
        }
      },
      "ReviewResultRequest": {
        "type": "object",
        "properties": {
          "verdict_string": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ReviewDecisionItem"
                }
              }
            ]
          }
        },
        "required": ["verdict_string"]
      },
      "SendEmailsRequest": {
        "type": "object",
        "properties": {
          "job_id": {
            "type": "string"
          },
          "jobId": {
            "type": "string"
          },
          "job_title": {
            "type": "string"
          }
        }
      },
      "FinalizeDecisionItem": {
        "type": "object",
        "properties": {
          "result_id": {
            "type": "string"
          },
          "resultId": {
            "type": "string"
          },
          "applicant_id": {
            "type": "string"
          },
          "applicantId": {
            "type": "string"
          },
          "verdict": {
            "type": "string",
            "enum": ["Shortlisted", "Rejected"]
          }
        },
        "required": ["verdict"]
      },
      "FinalizeJobRequest": {
        "type": "object",
        "properties": {
          "decisions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FinalizeDecisionItem"
            }
          }
        },
        "required": ["decisions"]
      },
      "ReviewApplicantRequest": {
        "type": "object",
        "properties": {
          "additional_info": {
            "type": "string"
          },
          "additionalInfo": {
            "type": "string"
          },
          "result_id": {
            "type": "string"
          },
          "screening_result_id": {
            "type": "string"
          }
        }
      },
      "SimpleAssistantRequest": {
        "type": "object",
        "properties": {
          "job_id": {
            "type": "string"
          },
          "question": {
            "type": "string"
          }
        },
        "required": ["question"]
      },
      "AssistantConversationRequest": {
        "type": "object",
        "properties": {
          "conversationId": {
            "type": "string"
          },
          "jobId": {
            "type": "string"
          },
          "applicantIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "maxApplicants": {
            "type": "integer",
            "minimum": 1,
            "maximum": 200,
            "default": 50
          },
          "question": {
            "type": "string",
            "maxLength": 4000
          }
        },
        "required": ["question"]
      },
      "ScreeningRouterRunRequest": {
        "type": "object",
        "properties": {
          "jobId": {
            "type": "string"
          },
          "applicantIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "topK": {
            "type": "integer",
            "minimum": 1,
            "maximum": 50,
            "default": 10
          }
        },
        "required": ["jobId"]
      }
    }
  }
}
