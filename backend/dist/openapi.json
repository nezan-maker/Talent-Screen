{
  "openapi": "3.1.0",
  "info": {
    "title": "Talvo Backend API",
    "version": "1.0.0",
    "description": "Current API surface for the Talvo backend. Auth is cookie-based, write operations require a matching CSRF cookie/header pair, and protected workspace data is scoped to the authenticated user's own records."
  },
  "servers": [
    {
      "url": "http://localhost:10000",
      "description": "Local development server"
    }
  ],
  "tags": [
    {
      "name": "Auth"
    },
    {
      "name": "Dashboard"
    },
    {
      "name": "Jobs"
    },
    {
      "name": "Candidates"
    },
    {
      "name": "Intake"
    },
    {
      "name": "Screening"
    },
    {
      "name": "Assistant"
    }
  ],
  "paths": {
    "/auth/csrf": {
      "get": {
        "tags": ["Auth"],
        "summary": "Issue CSRF token",
        "responses": {
          "200": {
            "description": "CSRF token response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "csrfToken": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/signup": {
      "post": {
        "tags": ["Auth"],
        "summary": "Create recruiter account",
        "description": "Accepts either a plain JSON body or the same payload nested under `reqBody`.",
        "parameters": [
          {
            "$ref": "#/components/parameters/CsrfHeader"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "$ref": "#/components/schemas/SignupRequest"
                  },
                  {
                    "type": "object",
                    "properties": {
                      "reqBody": {
                        "$ref": "#/components/schemas/SignupRequest"
                      }
                    },
                    "required": ["reqBody"]
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Signup successful"
          },
          "400": {
            "$ref": "#/components/responses/InputError"
          },
          "409": {
            "description": "Account already exists"
          }
        }
      }
    },
    "/auth/confirm": {
      "post": {
        "tags": ["Auth"],
        "summary": "Confirm signup OTP",
        "parameters": [
          {
            "$ref": "#/components/parameters/CsrfHeader"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "token": {
                    "type": "string",
                    "pattern": "^\\d{6}$"
                  },
                  "signup_token": {
                    "type": "string"
                  },
                  "signupToken": {
                    "type": "string"
                  }
                },
                "required": ["token"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Confirmation successful"
          },
          "400": {
            "$ref": "#/components/responses/InputError"
          },
          "401": {
            "description": "Expired or invalid token"
          },
          "404": {
            "$ref": "#/components/responses/DataError"
          }
        }
      }
    },
    "/auth/confirm_link/{confirmation_link_id}": {
      "get": {
        "tags": ["Auth"],
        "summary": "Confirm signup by link",
        "parameters": [
          {
            "in": "path",
            "name": "confirmation_link_id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "signup_token",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Confirmation successful"
          },
          "401": {
            "description": "Expired or invalid handler"
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login",
        "description": "Accepts either a plain JSON body or the same payload nested under `reqBody`.",
        "parameters": [
          {
            "$ref": "#/components/parameters/CsrfHeader"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "$ref": "#/components/schemas/LoginRequest"
                  },
