        },
        "responses": {
          "200": {
            "description": "Login successful"
          },
          "400": {
            "$ref": "#/components/responses/InputError"
          },
          "401": {
            "$ref": "#/components/responses/AuthError"
          },
          "404": {
            "$ref": "#/components/responses/DataError"
          }
        }
      }
    },
