{
  "openapi": "3.1.0",
  "info": {
    "title": "WiseRank API",
    "version": "1.0.0",
    "description": "WiseRank Recruiter Workspace – REST API for authentication, job management, applicant ingestion, AI-assisted screening, shortlisting and candidate email dispatch.",
    "contact": {
      "email": "hello@rankwise.io"
    }
  },
  "servers": [
    {
      "url": "http://localhost:5000",
      "description": "Local development server"
    }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "User registration, login and password recovery"
    },
    { "name": "Dashboard", "description": "Dashboard overview" },
    { "name": "Jobs", "description": "Job creation" },
    {
      "name": "Applicants",
      "description": "Applicant registration and file ingestion"
    },
    { "name": "Shortlist", "description": "AI shortlisting and manual review" },
    { "name": "Emails", "description": "Shortlist email dispatch" },
    { "name": "AI", "description": "Gemini-powered screening and assistant" }
  ],
  "paths": {
    "/auth/signup": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register a new recruiter account",
        "description": "Creates a new user, sends a 6-digit OTP to the provided email and sets a `signup_reference_token` cookie valid for 10 minutes.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignUpRequest"
              },
              "example": {
                "user_name": "Jane Doe",
                "user_email": "jane@acme.com",
                "user_pass": "Secure@123",
                "user_pass_conf": "Secure@123",
                "company_name": "Acme Corp"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Sign up successful. OTP sent by email.",
            "headers": {
              "Set-Cookie": {
                "description": "`signup_reference_token` (HttpOnly, 10 min)",
                "schema": { "type": "string" }
              }
            },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessMessage" },
                "example": { "success": "Sign up successful" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/InputError" },
          "401": {
            "description": "Account already exists",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MessageError" },
                "example": {
                  "message": "You already have an account please sign in"
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/auth/confirm": {
      "post": {
        "tags": ["Auth"],
        "summary": "Confirm email with OTP (token-based)",
        "description": "Validates the 6-digit OTP against the `signup_reference_token` cookie. On success marks the user as verified, issues `access_token` cookie and sends welcome email.",
        "parameters": [
          {
            "in": "cookie",
            "name": "signup_reference_token",
            "required": true,
            "schema": { "type": "string" },
            "description": "JWT set during signup, expires in 10 minutes"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["token"],
                "properties": {
                  "token": {
                    "type": "string",
                    "description": "6-digit OTP from email",
                    "example": "482910"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Email confirmed and access_token cookie set",
            "headers": {
              "Set-Cookie": {
                "description": "`access_token` (HttpOnly, 1 h)",
                "schema": { "type": "string" }
              }
            },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessMessage" },
                "example": { "success": "Confirmation successful" }
              }
            }
          },
          "401": {
            "description": "Cookie expired or OTP invalid",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    { "$ref": "#/components/schemas/ExpiredError" },
                    { "$ref": "#/components/schemas/AuthError" }
                  ]
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/auth/confirm_link/{confirmation_link_id}": {
      "get": {
        "tags": ["Auth"],
        "summary": "Confirm email via magic link",
        "description": "Alternative confirmation via the link sent in the signup email. Requires `signup_reference_token` cookie.",
        "parameters": [
          {
            "in": "path",
            "name": "confirmation_link_id",
            "required": true,
            "schema": { "type": "string" },
            "description": "Random 32-byte hex ID embedded in the confirmation link"
          },
          {
            "in": "cookie",
            "name": "signup_reference_token",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Email confirmed via link",
            "headers": {
              "Set-Cookie": {
                "description": "`access_token` (HttpOnly)",
                "schema": { "type": "string" }
              }
            },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessMessage" },
                "example": { "success": "Confirmation successful" }
              }
            }
          },
          "400": {
            "description": "URL incorrect or missing ID",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DataError" }
              }
            }
          },
          "401": {
            "description": "Cookie expired or ID mismatch",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    { "$ref": "#/components/schemas/ExpiredError" },
                    { "$ref": "#/components/schemas/DataError" }
                  ]
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Log in",
        "description": "Validates credentials. **Note:** the request body must be nested under a `reqBody` key.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["reqBody"],
                "properties": {
                  "reqBody": { "$ref": "#/components/schemas/LoginRequest" }
                }
              },
              "example": {
                "reqBody": {
                  "user_email": "jane@acme.com",
                  "user_pass": "Secure@123",
                  "user_pass_conf": "Secure@123"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessMessage" },
                "example": { "success": "Login successful" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/InputError" },
          "401": { "$ref": "#/components/responses/AuthError" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/auth/forgot": {
      "post": {
        "tags": ["Auth"],
        "summary": "Request password reset OTP",
        "description": "Sends a 6-digit reset code to the user's email and sets a `recovery_reference_token` cookie (10 min).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["user_email"],
                "properties": {
                  "user_email": {
                    "type": "string",
                    "format": "email",
                    "example": "jane@acme.com"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OTP sent",
            "headers": {
              "Set-Cookie": {
                "description": "`recovery_reference_token` (HttpOnly, 10 min)",
                "schema": { "type": "string" }
              }
            },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessMessage" },
                "example": { "success": "OTP token sent" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/InputError" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/auth/verify": {
      "post": {
        "tags": ["Auth"],
        "summary": "Verify password reset OTP",
        "description": "Checks the 6-digit OTP against the hashed token stored on the user. On success sets a `reset_reference_token` cookie. **Known bug:** `payload.id` should be `payload.user_id` – the user lookup currently always fails.",
        "parameters": [
          {
            "in": "cookie",
            "name": "recovery_reference_token",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["token"],
                "properties": {
                  "token": {
                    "type": "object",
                    "required": ["token"],
                    "properties": {
                      "token": {
                        "type": "string",
                        "pattern": "^[0-9]{6}$",
                        "example": "819302"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OTP verified, reset_reference_token cookie set",
            "headers": {
              "Set-Cookie": {
                "description": "`reset_reference_token` (HttpOnly, 10 min)",
                "schema": { "type": "string" }
              }
            },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessMessage" },
                "example": { "success": "Token verification successful" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/InputError" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/auth/reset": {
      "post": {
        "tags": ["Auth"],
        "summary": "Reset password",
        "description": "Sets a new password. Requires a valid `reset_reference_token` cookie. **Known bug:** `user.user_pass == hashedPassword` uses `==` (comparison) instead of `=` (assignment) so the password is never actually saved.",
        "parameters": [
          {
            "in": "cookie",
            "name": "reset_reference_token",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["reqBody"],
                "properties": {
                  "reqBody": { "$ref": "#/components/schemas/ResetRequest" }
                }
              },
              "example": {
                "reqBody": {
                  "user_pass": "NewSecure@456",
                  "user_pass_conf": "NewSecure@456"
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Password reset successful",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessMessage" },
                "example": { "success": "Password reset successful" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/InputError" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/dashboard": {
      "get": {
        "tags": ["Dashboard"],
        "summary": "Get dashboard overview",
        "description": "Returns a JSON-stringified array `[applicants[], jobs[]]`. Requires authentication cookie.",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": {
            "description": "Stringified dashboard data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "string",
                      "description": "JSON-encoded array of [applicants, jobs]",
                      "example": "[[{\"_id\":\"...\",\"applicant_name\":\"...\"}],[{\"_id\":\"...\",\"job_title\":\"...\"}]]"
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/AuthError" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/complete-job": {
      "post": {
        "tags": ["Jobs"],
        "summary": "Create a new job posting",
        "description": "Creates a Job document. The body must be JSON-stringified under the `reqString` key. Reads the company name from the `access_token` cookie. **Known bug:** reads cookie `reference_token` instead of `access_token`, so the user lookup always fails.",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["reqString"],
                "properties": {
                  "reqString": {
                    "type": "string",
                    "description": "JSON-stringified job object",
                    "example": "{\"job_title\":\"Backend Engineer\",\"job_department\":\"Engineering\",\"job_location\":\"Kigali, Rwanda\",\"job_employment_type\":\"Full-time\",\"job_requirements\":\"3+ years Node.js\",\"job_skills\":[\"Node.js\",\"MongoDB\"],\"job_qualifications\":\"BSc Computer Science\",\"workers_required\":2,\"job_notes\":[\"Remote-friendly\"]}"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Job created successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessMessage" },
                "example": { "success": "Job successfully created" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/InputError" },
          "401": {
            "description": "Job already exists",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MessageError" }
              }
            }
          },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/register-candidate": {
      "post": {
        "tags": ["Applicants"],
        "summary": "Register applicants (JSON or file upload)",
        "description": "Accepts either:\n- **Raw JSON** (`raw_application_data` string in body) for bulk applicant registration.\n- **Multipart upload** with `applicants_spreadsheet` (XLSX or CSV) + `resume_pdf_zip` (ZIP of PDFs). The ZIP filenames must match the applicant email or `first_name last_name` from the spreadsheet. Resumes are uploaded to Cloudinary and parsed via Gemini AI.",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["raw_application_data"],
                "properties": {
                  "raw_application_data": {
                    "type": "string",
                    "description": "JSON-stringified array of applicant objects",
                    "example": "[{\"first_name\":\"John\",\"last_name\":\"Smith\",\"email\":\"john@example.com\",\"job_title\":\"Backend Engineer\"}]"
                  }
                }
              }
            },
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["applicants_spreadsheet", "resume_pdf_zip"],
                "properties": {
                  "applicants_spreadsheet": {
                    "type": "string",
                    "format": "binary",
                    "description": "XLSX or CSV file with columns: first_name, last_name, email, job_title"
                  },
                  "resume_pdf_zip": {
                    "type": "string",
                    "format": "binary",
                    "description": "ZIP archive of PDF resumes. Filenames should be `applicant@email.com.pdf` or `First Last.pdf`"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Applicants registered",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessMessage" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/DataError" },
          "401": {
            "description": "Applicant email already registered",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DataError" }
              }
            }
          },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/ask": {
      "post": {
        "tags": ["Shortlist"],
        "summary": "AI shortlist – process and persist results",
        "description": "Parses `shortList_applicants` JSON string, updates applicant states (`Shortlisted` / `Rejected`), and calls the email controller via `next()`. **Note:** this is a middleware chain endpoint (`shortList → emailingController`).",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["shortList_applicants"],
                "properties": {
                  "shortList_applicants": {
                    "type": "string",
                    "description": "JSON-stringified array of shortlist decisions",
                    "example": "[{\"applicant_name\":\"John Smith\",\"shortlisted\":true},{\"applicant_name\":\"Jane Doe\",\"shortlisted\":false}]"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Shortlist processed and emails dispatched",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessMessage" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/InputError" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/review-result": {
      "post": {
        "tags": ["Shortlist"],
        "summary": "Record final verdict on applicants",
        "description": "Marks shortlisted applicants by setting `shortlisted: true` on the Applicant document. **Known bug:** no response is sent on success (missing `res.status(200).json(...)` call).",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["verdict_string"],
                "properties": {
                  "verdict_string": {
                    "type": "string",
                    "description": "JSON-stringified array of verdict objects",
                    "example": "[{\"applicant_name\":\"John Smith\",\"job_title\":\"Backend Engineer\",\"shortlisted\":true}]"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Verdicts saved (no body returned – see bug note)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessMessage" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/DataError" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/sendEmails": {
      "post": {
        "tags": ["Emails"],
        "summary": "Send shortlist notification emails",
        "description": "Finds all applicants with `shortlisted: true` for the given `job_title` and dispatches a shortlist email to each.",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["job_title"],
                "properties": {
                  "job_title": {
                    "type": "string",
                    "example": "Backend Engineer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Emails dispatched",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessMessage" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/DataError" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/ai/models": {
      "get": {
        "tags": ["AI"],
        "summary": "List available Gemini models",
        "description": "Proxies the Google Generative Language API models list.",
        "responses": {
          "200": {
            "description": "Model list from Google API",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/DataError" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/ai/run": {
      "post": {
        "tags": ["AI"],
        "summary": "Trigger AI screening run",
        "description": "Runs a Gemini screening against a job and its applicants. Creates a `ScreeningRun`, calls `screenWithGemini`, persists `ScreeningResult` documents and returns results. **Known bug:** env-guard condition uses `||` instead of `!env.VERTEX_PROJECT_ID || !env.VERTEX_LOCATION` — the guard fires even when the env vars are present.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TriggerScreeningRequest"
              },
              "example": {
                "job_id": "6630f4e2a1b2c3d4e5f60001",
                "applicant_ids": ["6630f4e2a1b2c3d4e5f60010"],
                "topK": 5
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Screening run completed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScreeningRunResponse"
                }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/ai/runs": {
      "get": {
        "tags": ["AI"],
        "summary": "List screening runs",
        "description": "Returns up to 200 screening runs, optionally filtered by `jobId`.",
        "parameters": [
          {
            "in": "query",
            "name": "jobId",
            "required": false,
            "schema": { "type": "string" },
            "description": "MongoDB ObjectId of the job to filter by"
          }
        ],
        "responses": {
          "200": {
            "description": "Array of ScreeningRun documents",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/ScreeningRun" }
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/ai/runs/{runId}": {
      "get": {
        "tags": ["AI"],
        "summary": "Get screening run results",
        "description": "Returns the run metadata and its sorted `ScreeningResult` documents. **Known bug:** query uses `screeningRunId` instead of `screening_run_id` (the schema field name), so results are always empty.",
        "parameters": [
          {
            "in": "path",
            "name": "runId",
            "required": true,
            "schema": { "type": "string" },
            "description": "MongoDB ObjectId of the screening run"
          }
        ],
        "responses": {
          "200": {
            "description": "Run and results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScreeningRunResponse"
                }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/ai/ask": {
      "post": {
        "tags": ["AI"],
        "summary": "Ask the AI assistant about applicants",
        "description": "Sends a natural-language question to Gemini along with job and applicant context. Returns an answer and suggested follow-up questions.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AskRequest" },
              "example": {
                "question": "Which applicants have the strongest TypeScript background?",
                "job_id": "6630f4e2a1b2c3d4e5f60001",
                "max_applicants": 50
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "AI answer",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AskResponse" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "access_token",
        "description": "HttpOnly JWT cookie set on login or email confirmation"
      }
    },
    "schemas": {
      "SignUpRequest": {
        "type": "object",
        "required": [
          "user_name",
          "user_email",
          "user_pass",
          "user_pass_conf",
          "company_name"
        ],
        "properties": {
          "user_name": { "type": "string", "minLength": 3 },
          "user_email": { "type": "string", "format": "email" },
          "user_pass": {
            "type": "string",
            "description": "Min 1 lowercase, 1 uppercase, 1 digit, 1 special character",
            "pattern": "^(?=.*[a-z])(?=.*[A-Z])(?=.*[0-9])(?=.*[^a-zA-Z0-9])"
          },
          "user_pass_conf": {
            "type": "string",
            "pattern": "^(?=.*[a-z])(?=.*[A-Z])(?=.*[0-9])(?=.*[^a-zA-Z0-9])"
          },
          "company_name": { "type": "string" }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["user_email", "user_pass", "user_pass_conf"],
        "properties": {
          "user_email": { "type": "string", "format": "email" },
          "user_pass": { "type": "string" },
          "user_pass_conf": { "type": "string" }
        }
      },
      "ResetRequest": {
        "type": "object",
        "required": ["user_pass", "user_pass_conf"],
        "properties": {
          "user_pass": {
            "type": "string",
            "pattern": "^(?=.*[a-z])(?=.*[A-Z])(?=.*[0-9])(?=.*[^a-zA-Z0-9])"
          },
          "user_pass_conf": {
            "type": "string",
            "pattern": "^(?=.*[a-z])(?=.*[A-Z])(?=.*[0-9])(?=.*[^a-zA-Z0-9])"
          }
        }
      },
      "TriggerScreeningRequest": {
        "type": "object",
        "required": ["job_id"],
        "properties": {
          "job_id": { "type": "string", "minLength": 1 },
          "applicant_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "description": "If omitted, all applicants for the job are used"
          },
          "topK": {
            "type": "integer",
            "minimum": 1,
            "maximum": 50,
            "default": 10,
            "description": "Number of top-ranked candidates to return"
          }
        }
      },
      "AskRequest": {
        "type": "object",
        "required": ["question"],
        "properties": {
          "question": { "type": "string", "minLength": 1, "maxLength": 4000 },
          "job_id": { "type": "string", "description": "Optional job context" },
          "applicant_ids": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Optional specific applicant subset"
          },
          "max_applicants": {
            "type": "integer",
            "minimum": 1,
            "maximum": 200,
            "default": 50
          }
        }
      },
      "AskResponse": {
        "type": "object",
        "properties": {
          "answer": { "type": "string" },
          "suggestedNextQuestions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "context": {
            "type": "object",
            "properties": {
              "jobId": { "type": "string", "nullable": true },
              "applicantCount": { "type": "integer" }
            }
          }
        }
      },
      "ScreeningRun": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "job_id": { "type": "string" },
          "applicants_ids": { "type": "array", "items": { "type": "string" } },
          "topK": { "type": "integer" },
          "status": {
            "type": "string",
            "enum": ["queued", "completed", "failed"]
          },
          "model": { "type": "string" },
          "error": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "ScreeningResult": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "screening_run_id": { "type": "string" },
          "job_id": { "type": "string" },
          "applicant_id": { "type": "string" },
          "rank": { "type": "integer" },
          "match_score": { "type": "number", "minimum": 0, "maximum": 100 },
          "strengths": { "type": "array", "items": { "type": "string" } },
          "gaps": { "type": "array", "items": { "type": "string" } },
          "recommendation": { "type": "string" }
        }
      },
      "ScreeningRunResponse": {
        "type": "object",
        "properties": {
          "runId": { "type": "string" },
          "results": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ScreeningResult" }
          }
        }
      },
      "SuccessMessage": {
        "type": "object",
        "properties": {
          "success": { "type": "string" }
        }
      },
      "MessageError": {
        "type": "object",
        "properties": {
          "message": { "type": "string" }
        }
      },
      "InputError": {
        "type": "object",
        "properties": {
          "input_error": { "type": "string" }
        }
      },
      "AuthError": {
        "type": "object",
        "properties": {
          "auth_error": { "type": "string" }
        }
      },
      "DataError": {
        "type": "object",
        "properties": {
          "data_error": { "type": "string" }
        }
      },
      "ExpiredError": {
        "type": "object",
        "properties": {
          "expired_error": { "type": "string" }
        }
      },
      "ServerError": {
        "type": "object",
        "properties": {
          "server_error": { "type": "string" }
        }
      }
    },
    "responses": {
      "InputError": {
        "description": "Validation / input error",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/InputError" }
          }
        }
      },
      "AuthError": {
        "description": "Authentication or authorisation failure",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/AuthError" }
          }
        }
      },
      "DataError": {
        "description": "Missing or invalid data",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/DataError" }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/DataError" },
            "example": { "data_error": "Resource not found" }
          }
        }
      },
      "ServerError": {
        "description": "Internal server error",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ServerError" },
            "example": { "server_error": "Internal server error" }
          }
        }
      }
    }
  }
}
