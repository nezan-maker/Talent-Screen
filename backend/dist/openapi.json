          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/CsrfHeader"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  },
                  "applicants_spreadsheet": {
                    "type": "string",
                    "format": "binary"
                  },
                  "default_job_id": {
                    "type": "string"
                  },
                  "default_job_title": {
                    "type": "string"
                  },
                  "job_id": {
                    "type": "string"
                  },
                  "job_title": {
                    "type": "string"
                  }
                }
              }
            },
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ApplicantInput"
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Applicants processed"
          },
          "400": {
            "$ref": "#/components/responses/DataError"
          }
        }
      }
    },
