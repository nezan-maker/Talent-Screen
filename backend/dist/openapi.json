{
  "openapi": "3.0.3",
  "info": {
    "title": "WiseRank API",
    "version": "1.0.0",
    "description": "An AI-assisted backend for authentication, candidate intake, dashboard reporting, and resume-based screening."
  },
  "servers": [
    {
      "url": "http://localhost:5000",
      "description": "Local development"
    },
    {
      "url": "/",
      "description": "Relative server URL"
    }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "Account registration, verification, login, and password recovery."
    },
    {
      "name": "Dashboard",
      "description": "Dashboard and aggregate data retrieval."
    },
    {
      "name": "Candidates",
      "description": "Candidate intake from JSON payloads or uploaded files."
    },
    {
      "name": "AI Screening",
      "description": "AI-assisted job setup and applicant screening."
    }
  ],
  "paths": {
    "/auth/signup": {
      "post": {
        "tags": ["Auth"],
        "summary": "Create an account",
        "description": "Registers a new WiseRank user and sets a short-lived `reference_token` cookie used by `/auth/confirm`.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignUpRequest"
              },
              "example": {
                "user_name": "Alice Uwimana",
                "user_email": "alice@example.com",
                "user_pass": "SecurePass1!",
                "user_pass_conf": "SecurePass1!"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Account created successfully.",
            "headers": {
              "Set-Cookie": {
                "description": "Sets the `reference_token` cookie for email confirmation.",
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SignUpResponse"
                },
                "example": {
                  "success": "Sign up successful",
                  "token": "431928"
                }
              }
            }
          },
          "400": {
            "description": "Password confirmation failed.",
            "content": {
              "application/json": {
                "example": {
                  "input_error": "Passwords must be the same"
                }
              }
            }
          },
          "401": {
            "description": "The user already exists or input validation failed.",
            "content": {
              "application/json": {
                "examples": {
                  "userExists": {
                    "value": {
                      "message": "You already have an account please sign in"
                    }
                  },
                  "validationError": {
                    "value": {
                      "input_error": "Input requirements not fulfilled"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "example": {
                  "server_error": "Internal server error"
                }
              }
            }
          }
        }
      }
    },
    "/auth/confirm": {
      "post": {
        "tags": ["Auth"],
        "summary": "Confirm a newly created account",
        "description": "Validates the OTP sent during signup. Requires the `reference_token` cookie created by `/auth/signup`.",
        "security": [
          {
            "referenceTokenCookie": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TokenRequest"
              },
              "example": {
                "token": "431928"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account confirmed successfully.",
            "headers": {
              "Set-Cookie": {
                "description": "Sets the `access_token` cookie on success.",
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "example": {
                  "success": "Confirmation successful"
                }
              }
            }
          },
          "401": {
            "description": "The OTP is invalid.",
            "content": {
              "application/json": {
                "example": {
                  "auth_error": "Invalid one time password entered"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "example": {
                  "server_error": "Internal server error"
                }
              }
            }
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Log in",
        "description": "Authenticates a verified user.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              },
              "example": {
                "user_email": "alice@example.com",
                "user_pass": "SecurePass1!"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login succeeded.",
            "content": {
              "application/json": {
                "example": {
                  "success": "Login successful"
                }
              }
            }
          },
          "400": {
            "description": "Input validation failed.",
            "content": {
              "application/json": {
                "example": {
                  "input_error": "Input requirements not fulfilled"
                }
              }
            }
          },
          "401": {
            "description": "The account is unverified or the credentials are invalid.",
            "content": {
              "application/json": {
                "examples": {
                  "notVerified": {
                    "value": {
                      "auth_error": "Account not verified please confirm by email"
                    }
                  },
                  "invalidCredentials": {
                    "value": {
                      "auth_error": "Invalid credentials"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "The user was not found.",
            "content": {
              "application/json": {
                "example": {
                  "data_error": "User is not found.Kindly consider creating an account"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "example": {
                  "server_error": "Internal server error"
                }
              }
            }
          }
        }
      }
    },
    "/auth/forgot": {
      "post": {
        "tags": ["Auth"],
        "summary": "Start password recovery",
        "description": "Looks up a user by email, creates a password-reset OTP, and sets a temporary `reference_token` cookie used by `/auth/verify`.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ForgotPasswordRequest"
              },
              "example": {
                "user_email": "alice@example.com"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reset flow started successfully.",
            "headers": {
              "Set-Cookie": {
                "description": "Sets the `reference_token` cookie for OTP verification.",
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "example": {
                  "success": "OTP token sent"
                }
              }
            }
          },
          "400": {
            "description": "Input validation failed.",
            "content": {
              "application/json": {
                "examples": {
                  "validationError": {
                    "value": {
                      "input_error": "Input requirements are not fulfilled"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "The user was not found.",
            "content": {
              "application/json": {
                "example": {
                  "data_error": "User not found in the database consider creating account"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "example": {
                  "server_error": "Internal server error"
                }
              }
            }
          }
        }
      }
    },
    "/auth/verify": {
      "post": {
        "tags": ["Auth"],
        "summary": "Verify password-reset OTP",
        "description": "Checks the recovery OTP sent during `/auth/forgot`. Requires the `reference_token` cookie from that step.",
        "security": [
          {
            "referenceTokenCookie": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TokenRequest"
              },
              "example": {
                "token": "431928"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OTP verified successfully.",
            "headers": {
              "Set-Cookie": {
                "description": "Sets the `reset_token` cookie used by `/auth/reset`.",
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "example": {
                  "success": "Token verification successful"
                }
              }
            }
          },
          "401": {
            "description": "The OTP is invalid or the request is malformed.",
            "content": {
              "application/json": {
                "examples": {
                  "invalidOtp": {
                    "value": {
                      "input_error": "Invalid one time password"
                    }
                  },
                  "validationError": {
                    "value": {
                      "input_error": "Input requirements not fulfilled"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "example": {
                  "server_error": "Internal server error"
                }
              }
            }
          }
        }
      }
    },
    "/auth/reset": {
      "post": {
        "tags": ["Auth"],
        "summary": "Reset a password",
        "description": "Sets a new password after `/auth/verify`. Requires the `reset_token` cookie.",
        "security": [
          {
            "resetTokenCookie": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResetPasswordRequest"
              },
              "example": {
                "user_pass": "NewSecurePass1!",
                "user_pass_conf": "NewSecurePass1!"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Password reset succeeded.",
            "content": {
              "application/json": {
                "example": {
                  "success": "Password reset successful"
                }
              }
            }
          },
          "401": {
            "description": "Password confirmation failed or the reset flow is invalid.",
            "content": {
              "application/json": {
                "examples": {
                  "passwordMismatch": {
                    "value": {
                      "input_error": "Passwords must be the same"
                    }
                  },
                  "expiredFlow": {
                    "value": {
                      "expiration_error": "Reset password handlers expired try again later"
                    }
                  },
                  "validationError": {
                    "value": {
                      "input_error": "Input requirements not fulfilled"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "example": {
                  "server_error": "Internal server error"
                }
              }
            }
          }
        }
      }
    },
    "/dashboard": {
      "get": {
        "tags": ["Dashboard"],
        "summary": "Fetch dashboard data",
        "description": "Returns dashboard data as a JSON-stringified array in the order `[applicants, jobs]`.",
        "responses": {
          "200": {
            "description": "Dashboard payload returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string",
                  "description": "Stringified JSON containing an array with applicants at index 0 and jobs at index 1."
                },
                "example": "[[{\"applicant_name\":\"John Doe\",\"job_title\":\"Junior Fullstack Developer\",\"skills\":\"Node.js, React\",\"education\":\"BSc Computer Science\",\"experience\":2,\"additional_info\":\"Immediate starter\",\"shortlisted\":false}],[{\"job_title\":\"Junior Fullstack Developer\",\"job_department\":\"Engineering\",\"job_location\":\"Kigali\",\"job_employment_type\":\"Full-time\",\"job_salary_min\":500,\"job_salary_max\":900,\"job_experience_required\":\"2 years\",\"job_ai_criteria\":[{\"criteria_string\":\"Core requirements\",\"description\":\"Frontend and backend fundamentals\",\"priority\":\"High\"}],\"workers_required\":1,\"job_state\":\"Uninitialised\"}]]"
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "examples": {
                  "errorShapeOne": {
                    "value": {
                      "error": "Internal server error"
                    }
                  },
                  "errorShapeTwo": {
                    "value": {
                      "message": "Internal server error"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/register-candidate": {
      "post": {
        "tags": ["Candidates"],
        "summary": "Register candidates",
        "description": "Registers candidates either from JSON data or by uploading a spreadsheet together with a ZIP of PDF resumes. The JSON flow expects `raw_application_data` as a stringified JSON array. The multipart flow expects the spreadsheet and ZIP fields used by the controller (`applicant_spreadsheet` and `pdf_resume_zip`).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CandidateJsonRegistrationRequest"
              },
              "example": {
                "raw_application_data": "[{\"applicant_name\":\"Alice Uwimana\",\"job_title\":\"Full Stack Developer\"},{\"applicant_name\":\"Eric Ndayisaba\",\"job_title\":\"Full Stack Developer\"}]"
              }
            },
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/CandidateMultipartRegistrationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Candidates were processed successfully.",
            "content": {
              "application/json": {
                "examples": {
                  "spreadsheetUpload": {
                    "value": {
                      "success": "Applicants successfully registered from spreadsheet file"
                    }
                  },
                  "jsonRegistration": {
                    "value": {
                      "success": "Applicant successfully registered"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "The request body, upload, or spreadsheet structure is invalid.",
            "content": {
              "application/json": {
                "examples": {
                  "missingInfo": {
                    "value": {
                      "data_error": "Info about the applicants required"
                    }
                  },
                  "badFileType": {
                    "value": {
                      "data_error": "File type not allowed"
                    }
                  },
                  "badSpreadsheet": {
                    "value": {
                      "data_error": "Spreadsheet does not match required structure"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "A duplicate applicant was found.",
            "content": {
              "application/json": {
                "example": {
                  "data_error": "User named Alice Uwimana is already registered for this job"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "example": {
                  "server_error": "Internal server error"
                }
              }
            }
          }
        }
      }
    },
    "/ask": {
      "post": {
        "tags": ["AI Screening"],
        "summary": "Generate screening results for a job",
        "description": "Builds an AI prompt from the matching job and applicants, then stores the generated screening result.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AskGeminiRequest"
              },
              "example": {
                "jobTitle": "Full Stack Developer"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Screening result generated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AskGeminiResponse"
                },
                "example": {
                  "success": {
                    "job_title": "Full Stack Developer",
                    "result_verdict": "Top candidates shortlisted based on overall performance and relevance",
                    "applicants_details": [
                      {
                        "applicant_id": "APP-001",
                        "applicant_name": "Alice Uwimana",
                        "applicant_marks": 87.5,
                        "applicant_specification_relevance": {
                          "skills_relevance": 90,
                          "education_relevance": 85
                        },
                        "applicant_result_description": "Strong in both frontend and backend technologies. Demonstrated solid understanding of system design and APIs."
                      }
                    ]
                  }
                }
              }
            }
          },
          "400": {
            "description": "The requested job could not be found in an active state.",
            "content": {
              "application/json": {
                "example": {
                  "data_error": "Could not find an active job that matches what is specified"
                }
              }
            }
          },
          "404": {
            "description": "No applicants were found for the requested job.",
            "content": {
              "application/json": {
                "example": {
                  "data_error": "No active applicants for the job Full Stack Developer yet"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "example": {
                  "server_error": "Internal server error"
                }
              }
            }
          }
        }
      }
    },
    "/complete-job": {
      "post": {
        "tags": ["AI Screening"],
        "summary": "Create a job and generate its example form",
        "description": "Creates a job record, asks Gemini for an example candidate form, and stores the generated example on the job.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CompleteJobRequest"
              },
              "example": {
                "reqBody": {
                  "job_title": "Full Stack Developer",
                  "job_department": "Engineering",
                  "job_location": "Kigali",
                  "job_employment_type": "Full-time",
                  "job_salary_min": 1200,
                  "job_salary_max": 2200,
                  "job_experience_required": "3+ years",
                  "job_ai_criteria": [
                    {
                      "criteria_string": "Core requirements",
                      "description": "Strong React, Node.js, and SQL skills",
                      "priority": "High"
                    },
                    {
                      "criteria_string": "Nice to have",
                      "description": "Cloud deployment experience",
                      "priority": "Medium"
                    }
                  ],
                  "workers_required": 1,
                  "job_state": "Active"
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Job created and example form generated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompleteJobResponse"
                },
                "example": {
                  "success": "Job created successfully",
                  "job": {
                    "job_title": "Full Stack Developer",
                    "job_department": "Engineering",
                    "job_location": "Kigali",
                    "job_employment_type": "Full-time",
                    "job_salary_min": 1200,
                    "job_salary_max": 2200,
                    "job_experience_required": "3+ years",
                    "job_ai_criteria": [
                      {
                        "criteria_string": "Core requirements",
                        "description": "Strong React, Node.js, and SQL skills",
                        "priority": "High"
                      }
                    ],
                    "workers_required": 1,
                    "job_state": "Uninitialised",
                    "job_example_form": {
                      "SKILLS": ["React", "Node.js", "SQL"]
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "The request body does not contain a valid `reqBody` object.",
            "content": {
              "application/json": {
                "example": {
                  "data_error": "Incorrect job structure"
                }
              }
            }
          },
          "401": {
            "description": "A job with the same title already exists.",
            "content": {
              "application/json": {
                "example": {
                  "message": "Job already registered"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "example": {
                  "server_error": "Internal server error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "referenceTokenCookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "reference_token"
      },
      "resetTokenCookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "reset_token"
      }
    },
    "schemas": {
      "SignUpRequest": {
        "type": "object",
        "required": ["user_name", "user_email", "user_pass", "user_pass_conf"],
        "properties": {
          "user_name": {
            "type": "string",
            "minLength": 3
          },
          "user_email": {
            "type": "string",
            "format": "email"
          },
          "user_pass": {
            "type": "string",
            "format": "password",
            "description": "Must contain uppercase, lowercase, number, and special character."
          },
          "user_pass_conf": {
            "type": "string",
            "format": "password",
            "description": "Must match `user_pass`."
          }
        }
      },
      "SignUpResponse": {
        "type": "object",
        "required": ["success", "token"],
        "properties": {
          "success": {
            "type": "string"
          },
          "token": {
            "type": "string",
            "description": "Development OTP token returned by the current backend implementation."
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["user_email", "user_pass"],
        "properties": {
          "user_email": {
            "type": "string",
            "format": "email"
          },
          "user_pass": {
            "type": "string",
            "format": "password"
          }
        }
      },
      "ForgotPasswordRequest": {
        "type": "object",
        "required": ["user_email"],
        "properties": {
          "user_email": {
            "type": "string",
            "format": "email"
          }
        }
      },
      "TokenRequest": {
        "type": "object",
        "required": ["token"],
        "properties": {
          "token": {
            "type": "string"
          }
        }
      },
      "ResetPasswordRequest": {
        "type": "object",
        "required": ["user_pass", "user_pass_conf"],
        "properties": {
          "user_pass": {
            "type": "string",
            "format": "password"
          },
          "user_pass_conf": {
            "type": "string",
            "format": "password"
          }
        }
      },
      "ApplicantInput": {
        "type": "object",
        "required": ["applicant_name", "job_title"],
        "properties": {
          "applicant_name": {
            "type": "string"
          },
          "job_title": {
            "type": "string"
          }
        }
      },
      "CandidateJsonRegistrationRequest": {
        "type": "object",
        "required": ["raw_application_data"],
        "properties": {
          "raw_application_data": {
            "type": "string",
            "description": "A JSON-stringified array of applicant objects."
          }
        }
      },
      "CandidateMultipartRegistrationRequest": {
        "type": "object",
        "required": ["applicant_spreadsheet", "pdf_resume_zip"],
        "properties": {
          "applicant_spreadsheet": {
            "type": "string",
            "format": "binary",
            "description": "CSV or XLSX spreadsheet containing applicant rows."
          },
          "pdf_resume_zip": {
            "type": "string",
            "format": "binary",
            "description": "ZIP archive containing applicant resumes as PDFs."
          }
        }
      },
      "ApplicantRecord": {
        "type": "object",
        "properties": {
          "applicant_name": {
            "type": "string"
          },
          "job_title": {
            "type": "string"
          },
          "skills": {
            "type": "string"
          },
          "education": {
            "type": "string"
          },
          "experience": {
            "type": "number"
          },
          "additional_info": {
            "type": "string"
          },
          "shortlisted": {
            "type": "boolean"
          }
        }
      },
      "JobDescription": {
        "type": "object",
        "required": ["criteria_string", "description", "priority"],
        "properties": {
          "criteria_string": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "priority": {
            "type": "string"
